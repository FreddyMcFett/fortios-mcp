# ---------------------------------------------------------------------------
# FortiOS MCP — environment configuration
# Copy to `.env` and fill in the values, then `chmod 600 .env`.
# ---------------------------------------------------------------------------

# FortiGate connection (REQUIRED)
FORTIOS_HOST=192.168.1.99
FORTIOS_PORT=443
FORTIOS_API_TOKEN=

# TLS / timeouts
FORTIOS_VERIFY_SSL=true
FORTIOS_TIMEOUT=30
FORTIOS_MAX_RETRIES=3

# Default VDOM (leave as "root" on non-multi-VDOM deployments)
FORTIOS_DEFAULT_VDOM=root

# Safety: set to true to allow set/add/update/delete/execute tools to run
FORTIOS_ENABLE_WRITES=false

# MCP server runtime
MCP_SERVER_MODE=auto            # auto | stdio | http
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8002
# MCP_AUTH_TOKEN=                # Bearer token required in HTTP mode
# MCP_ALLOWED_HOSTS=mcp.example  # Comma-separated, protects against DNS rebinding

# Tool loading — "full" registers everything, "dynamic" only discovery tools
FORTIOS_TOOL_MODE=full

# Logging
LOG_LEVEL=INFO
# LOG_FILE=logs/fortios-mcp.log
