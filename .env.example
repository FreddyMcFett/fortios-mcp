# ---------------------------------------------------------------------------
# FortiOS MCP Server — environment configuration
# Copy this file to .env, fill in the values, then `chmod 600 .env`.
# ---------------------------------------------------------------------------

# =============================================================================
# FortiGate connection (REQUIRED)
# =============================================================================

# FortiGate hostname or IP address
FORTIOS_HOST=192.168.1.99

# HTTPS port
FORTIOS_PORT=443

# REST API admin token
# Generate on the FortiGate with:
#   execute api-user generate-key <name>
FORTIOS_API_TOKEN=

# =============================================================================
# TLS / timeouts
# =============================================================================

# Set to false for self-signed certificates (not recommended for production)
FORTIOS_VERIFY_SSL=true

# Per-request timeout (seconds)
FORTIOS_TIMEOUT=30

# Retries on 429 / 5xx / network error
FORTIOS_MAX_RETRIES=3

# =============================================================================
# Default VDOM
# =============================================================================

# Leave as "root" on non-multi-VDOM deployments
FORTIOS_DEFAULT_VDOM=root

# =============================================================================
# Safety
# =============================================================================

# Set to true to allow set/add/update/delete/execute tools to run.
# Read-only by default — even with writes enabled, review the model's
# proposed change before approving the call.
FORTIOS_ENABLE_WRITES=false

# =============================================================================
# MCP Server runtime
# =============================================================================

# Server mode: 'http' for Docker, 'stdio' for Claude Desktop, 'auto' to detect
MCP_SERVER_MODE=auto

# Server bind address (0.0.0.0 for Docker, 127.0.0.1 for local only)
MCP_SERVER_HOST=0.0.0.0

# Server port
MCP_SERVER_PORT=8002

# Bearer token for HTTP authentication (optional but strongly recommended).
# If set, all HTTP requests (except /health) require
# Authorization: Bearer <token>. If unset, the server runs without auth
# — keep the endpoint on a private network!
# MCP_AUTH_TOKEN=

# Additional allowed Host header values for DNS rebinding protection.
# Required when running behind a reverse proxy (Traefik, nginx, etc.).
# The MCP SDK rejects non-localhost Host headers by default.
# Format: JSON array or comma-separated list, e.g., ["mcp.example.com"]
# MCP_ALLOWED_HOSTS=

# Tool loading:
#   'full'    — register everything (higher context usage)
#   'dynamic' — register only schema-discovery tools
FORTIOS_TOOL_MODE=full

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional log file path (leave unset for console only)
# LOG_FILE=logs/fortios-mcp.log

# Log format
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
